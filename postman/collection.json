                "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                "const j = pm.response.json();",
                "pm.test(\"Token válido\", () => pm.expect(j.valid).to.be.true);",
                "pm.test(\"Tiene user_id\", () => pm.expect(j.user_id).to.be.a(\"string\").and.not.be.empty);"
              ]
            }
          }]
        },
        {
          "name": "POST /auth/refresh",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "refresh"]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                "const j = pm.response.json();",
                "pm.test(\"Nuevo access_token\", () => pm.expect(j.access_token).to.be.a(\"string\").and.not.be.empty);",
                "pm.collectionVariables.set(\"token\", j.access_token);",
                "pm.collectionVariables.set(\"refreshToken\", j.refresh_token);"
              ]
            }
          }]
        },
        {
          "name": "POST /auth/revoke-all",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
