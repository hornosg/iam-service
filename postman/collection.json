    {
      "name": "7. Multi-Tenant Isolation",
      "description": "Crea Tenant B + User B; verifica que los listados y accesos no se mezclan entre tenants.",
      "item": [
        {
          "name": "POST /tenants — crear Tenant B",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tenant B Isolation Test\",\n  \"slug\": \"tenant-b-isolation\",\n  \"description\": \"Segundo tenant para pruebas de aislamiento\",\n  \"type\": \"BUSINESS\",\n  \"owner_id\": \"{{adminUserId}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/tenants",
              "host": ["{{baseUrl}}"],
              "path": ["tenants"]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test(\"Status 201\", () => pm.response.to.have.status(201));",
                "const j = pm.response.json();",
                "pm.test(\"Slug correcto\", () => pm.expect(j.slug).to.eql(\"tenant-b-isolation\"));",
                "pm.collectionVariables.set(\"tenantBId\", j.id);",
