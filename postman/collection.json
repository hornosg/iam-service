  "item": [
    {
      "name": "1. Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{hostUrl}}/health",
              "host": ["{{hostUrl}}"],
              "path": ["health"]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                "pm.test(\"Service up\", () => pm.expect(pm.response.json().status).to.eql(\"up\"));"
              ]
            }
          }]
        }
      ]
    },
    {
      "name": "2. Auth Bootstrap",
      "item": [
        {
          "name": "POST /auth/login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\",\n  \"provider\": \"LOCAL\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                "const j = pm.response.json();",
                "pm.test(\"Has access_token\", () => pm.expect(j.access_token).to.be.a(\"string\").and.not.be.empty);",
                "pm.test(\"Token type Bearer\", () => pm.expect(j.token_type).to.eql(\"Bearer\"));",
                "pm.collectionVariables.set(\"token\", j.access_token);",
                "pm.collectionVariables.set(\"refreshToken\", j.refresh_token);",
                "pm.collectionVariables.set(\"adminUserId\", j.user.id);"
              ]
            }
          }]
        }
      ]
    },
